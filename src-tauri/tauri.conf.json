{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Sumgim",
  "version": "0.4.0",
  "identifier": "dev.minju.sumgim",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "숨김 · Sumgim",
        "width": 680,
        "height": 720,
        "minWidth": 520,
        "minHeight": 520,
        "resizable": true,
        "visible": false,
        "decorations": true,
        "center": true
      },
      {
        "label": "floating",
        "url": "index.html",
        "title": "Sumgim toggle",
        "width": 64,
        "height": 64,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "shadow": false,
        "focus": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.png"
    ]
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/minju-kim98/sumgim/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQ3NUVCRDM4MURGRDhFNjUKUldSbGp2MGRPTDFlUitFSWgrdjhKR3BScFJMa2sxQVJ3NG1CemhGRjh6am5wNUh1aGR6NG1YdnYK",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
